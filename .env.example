# Copy this file to .env and fill in your own values.
# .env is gitignored; this template is tracked so the required keys stay documented.
#
# Only needed for the scrapers that sign in. Uploading files and searching
# work without any of these set.

# FamilySearch account, used by Scraping/FamilySearch.py
FAMILYSEARCH_USERNAME=your-familysearch-username
FAMILYSEARCH_PASSWORD=your-familysearch-password

# MyChinaRoots, accessed via the SCCL library proxy login.
# Username is your library card number, password is its PIN.
# Used by Scraping/MCR.py
MCR_USERNAME=your-library-card-number
MCR_PASSWORD=your-library-pin
